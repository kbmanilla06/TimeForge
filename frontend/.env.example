# Production (Sprint 43): point at the deployed backend's own public URL
# (e.g. https://api.your-domain.example) — must also be listed in the
# backend's FRONTEND_URL/CORS_ALLOWED_ORIGINS for this frontend's own
# origin, or API requests will be rejected by CORS.
VITE_API_URL=http://localhost:8000

# Cloudflare Turnstile (Sprint 37) — must match the backend's
# TURNSTILE_SITE_KEY. Defaults to Cloudflare's own published "always
# passes" test site key, safe for local dev — swap for your real site
# key before production.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
