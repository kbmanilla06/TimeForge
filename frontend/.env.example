VITE_API_URL=http://localhost:8000

# Cloudflare Turnstile (Sprint 37) — must match the backend's
# TURNSTILE_SITE_KEY. Defaults to Cloudflare's own published "always
# passes" test site key, safe for local dev — swap for your real site
# key before production.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
