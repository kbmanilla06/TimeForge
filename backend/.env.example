APP_NAME=TimeForge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=timeforge
DB_USERNAME=timeforge
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local/dev default: every notification (including Sprint 36's
# registration OTP) writes to storage/logs/laravel.log instead of sending
# real mail. To send through Google's SMTP relay instead (required for
# real OTP delivery), switch to the block below and supply your own
# credentials — never commit real values here.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Google SMTP relay (Sprint 36) — uncomment and fill in to send real mail.
# Port 587 auto-negotiates STARTTLS (Symfony Mailer default) — leave
# MAIL_SCHEME unset; this app's config/mail.php doesn't read MAIL_ENCRYPTION.
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-gmail-address@gmail.com
# # A 16-character Gmail App Password, not your normal account password —
# # requires 2-Step Verification enabled on the Google account:
# # https://myaccount.google.com/apppasswords
# MAIL_PASSWORD=your-16-character-app-password
# MAIL_FROM_ADDRESS=your-gmail-address@gmail.com
# MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Global overtime multiplier applied to approved overtime hours
# (Sprint 8 decision: env-configurable only, no settings UI).
PAYROLL_OVERTIME_MULTIPLIER=1.25

# AI provider for AI Insights. Only "stub" (local, deterministic,
# no network calls, no credentials) is implemented; any other value
# throws at boot. Real provider selection is an open decision.
AI_PROVIDER=stub

VITE_APP_NAME="${APP_NAME}"
