# Production (Sprint 39): APP_ENV=production, APP_DEBUG=false (never true
# in production — it leaks stack traces/config to error responses), a
# real APP_URL/FRONTEND_URL for your deployed domains, and a freshly
# generated APP_KEY (`php artisan key:generate` — never reuse this or
# any other environment's key).
APP_NAME=TimeForge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Sprint 39: local dev and production both run Postgres (dev/prod
# parity) — local dev connects to the docker-compose "postgres" service
# (or your own local Postgres install), production connects to a
# Supabase-hosted Postgres instance. Only the connection details differ.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=timeforge
DB_USERNAME=timeforge
DB_PASSWORD=secret

# Supabase Postgres (production) — uncomment and fill in from your
# Supabase project's Database settings. Supabase requires SSL; the
# direct-connection host works for low-connection-count apps, or use
# the connection pooler host (port 6543) if you expect many concurrent
# connections: https://supabase.com/docs/guides/database/connecting-to-postgres
# DB_HOST=db.your-project-ref.supabase.co
# DB_PORT=5432
# DB_DATABASE=postgres
# DB_USERNAME=postgres
# DB_PASSWORD=your-database-password
# DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local/dev default: every notification (including Sprint 36's
# registration OTP) writes to storage/logs/laravel.log instead of sending
# real mail. To send through Google's SMTP relay instead (required for
# real OTP delivery), switch to the block below and supply your own
# credentials — never commit real values here.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Google SMTP relay (Sprint 36) — uncomment and fill in to send real mail.
# Port 587 auto-negotiates STARTTLS (Symfony Mailer default) — leave
# MAIL_SCHEME unset; this app's config/mail.php doesn't read MAIL_ENCRYPTION.
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-gmail-address@gmail.com
# # A 16-character Gmail App Password, not your normal account password —
# # requires 2-Step Verification enabled on the Google account:
# # https://myaccount.google.com/apppasswords
# MAIL_PASSWORD=your-16-character-app-password
# MAIL_FROM_ADDRESS=your-gmail-address@gmail.com
# MAIL_FROM_NAME="${APP_NAME}"

# CAPTCHA (Sprint 37) — gates POST /forgot-password and /reset-password
# only. Ships with Cloudflare Turnstile's own published "always passes"
# test key pair below, so local dev/tests work without real keys — swap
# both for your real site/secret key pair from the Cloudflare dashboard
# before production: https://developers.cloudflare.com/turnstile/
CAPTCHA_ENABLED=true
CAPTCHA_PROVIDER=turnstile
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Local/dev default: attachments and profile pictures write to the
# private local disk (storage/app/private). FILESYSTEM_DISK is read by
# every upload/download/delete call in the app (Sprint 39 fixed several
# call sites that used to hardcode 'local' and ignore this setting).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Supabase Storage (production, Sprint 39) — uncomment and fill in from
# your Supabase project's Storage settings. Supabase Storage is
# S3-compatible, so it plugs into the existing generic "s3" disk driver
# with no code changes: https://supabase.com/docs/guides/storage/s3/compatibility
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=your-supabase-storage-access-key-id
# AWS_SECRET_ACCESS_KEY=your-supabase-storage-secret-access-key
# AWS_DEFAULT_REGION=your-project-region
# AWS_BUCKET=your-bucket-name
# AWS_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
# AWS_USE_PATH_STYLE_ENDPOINT=true

# Global overtime multiplier applied to approved overtime hours
# (Sprint 8 decision: env-configurable only, no settings UI).
PAYROLL_OVERTIME_MULTIPLIER=1.25

# AI provider for AI Insights. Only "stub" (local, deterministic,
# no network calls, no credentials) is implemented; any other value
# throws at boot. Real provider selection is an open decision.
AI_PROVIDER=stub

VITE_APP_NAME="${APP_NAME}"
