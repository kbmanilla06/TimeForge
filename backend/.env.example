# Production (Sprint 39, expanded Sprint 43): APP_ENV=production,
# APP_DEBUG=false (never true in production — it leaks stack traces/config
# to error responses), a freshly generated APP_KEY (`php artisan
# key:generate` — never reuse this or any other environment's key).
#
# APP_URL must be this backend's own public URL (e.g.
# https://api.your-domain.example) — it's used to generate correct
# absolute links from Artisan/queued jobs, not the frontend's address.
# FRONTEND_URL must be the deployed SPA's origin (e.g.
# https://app.your-domain.example) — used to build links that must point
# at the SPA (e.g. password-reset emails), and doubles as the CORS
# allowed-origin default below unless CORS_ALLOWED_ORIGINS is set.
APP_NAME=TimeForge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# CORS (Sprint 43) — defaults to FRONTEND_URL above (the single-SPA
# case). Set this instead (comma-separated) if multiple frontend origins
# need access — e.g. staging + production sharing one backend. Never a
# wildcard in production; never a real domain committed here.
# CORS_ALLOWED_ORIGINS=https://staging.your-domain.example,https://app.your-domain.example

# Trusted proxies (Sprint 43) — required for correct HTTPS detection when
# this app sits behind a TLS-terminating reverse proxy/load balancer, so
# generated URLs and secure-cookie logic see the connection as HTTPS
# rather than the plain-HTTP hop between the proxy and this app. Leave
# unset locally (nothing proxies the Docker stack). Comma-separated
# IPs/CIDRs, or '*' only if your deployment topology guarantees no
# untrusted client can reach the app directly.
# TRUSTED_PROXIES=10.0.0.0/8

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Sprint 39: local dev and production both run Postgres (dev/prod
# parity) — local dev connects to the docker-compose "postgres" service
# (or your own local Postgres install), production connects to a
# Supabase-hosted Postgres instance. Only the connection details differ.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=timeforge
DB_USERNAME=timeforge
DB_PASSWORD=secret

# Supabase Postgres (production) — uncomment and fill in from your
# Supabase project's Database settings. Supabase requires SSL; the
# direct-connection host works for low-connection-count apps, or use
# the connection pooler host (port 6543) if you expect many concurrent
# connections: https://supabase.com/docs/guides/database/connecting-to-postgres
# DB_HOST=db.your-project-ref.supabase.co
# DB_PORT=5432
# DB_DATABASE=postgres
# DB_USERNAME=postgres
# DB_PASSWORD=your-database-password
# DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local/dev default: every notification (including Sprint 36's
# registration OTP) writes to storage/logs/laravel.log instead of sending
# real mail. For production, dedicated transactional email providers (Resend,
# Postmark, SES, or Mailgun) are highly recommended.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Option 1: Transactional Provider (Recommended for Production — e.g. Resend, Postmark, SES)
# API keys are highly preferred over SMTP for reliability and deliverability.
#
# E.g. For Resend/Postmark API transport (configure the driver in config/mail.php):
# MAIL_MAILER=resend # or postmark, ses, mailgun
# RESEND_KEY=re_your_api_key
# POSTMARK_TOKEN=your_postmark_token
#
# E.g. For Transactional SMTP configuration:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.resend.com # or smtp.postmarkapp.com, email-smtp.us-east-1.amazonaws.com
# MAIL_PORT=587
# MAIL_USERNAME=resend # or your SMTP username
# MAIL_PASSWORD=re_your_smtp_key # or your SMTP password
# MAIL_FROM_ADDRESS=notifications@your-verified-domain.com
# MAIL_FROM_NAME="${APP_NAME}"

# Option 2: Google SMTP Relay (Local/dev only — not recommended for production)
# WARNING: Standard Google password authentication is deprecated. Personal Gmail SMTP
# is heavily rate-limited and will fail when called from cloud provider IPs.
# If used, requires a 16-character App Password (requires 2-Step Verification):
# https://myaccount.google.com/apppasswords
#
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-gmail-address@gmail.com
# MAIL_PASSWORD=your-16-character-app-password
# MAIL_FROM_ADDRESS=your-gmail-address@gmail.com
# MAIL_FROM_NAME="${APP_NAME}"

# CAPTCHA (Sprint 37) — gates POST /forgot-password and /reset-password
# only. Ships with Cloudflare Turnstile's own published "always passes"
# test key pair below, so local dev/tests work without real keys — swap
# both for your real site/secret key pair from the Cloudflare dashboard
# before production: https://developers.cloudflare.com/turnstile/
CAPTCHA_ENABLED=true
CAPTCHA_PROVIDER=turnstile
TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Local/dev default: attachments and profile pictures write to the
# private local disk (storage/app/private). FILESYSTEM_DISK is read by
# every upload/download/delete call in the app (Sprint 39 fixed several
# call sites that used to hardcode 'local' and ignore this setting).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Supabase Storage (production, Sprint 39) — uncomment and fill in from
# your Supabase project's Storage settings. Supabase Storage is
# S3-compatible, so it plugs into the existing generic "s3" disk driver
# with no code changes: https://supabase.com/docs/guides/storage/s3/compatibility
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=your-supabase-storage-access-key-id
# AWS_SECRET_ACCESS_KEY=your-supabase-storage-secret-access-key
# AWS_DEFAULT_REGION=your-project-region
# AWS_BUCKET=your-bucket-name
# AWS_ENDPOINT=https://your-project-ref.supabase.co/storage/v1/s3
# AWS_USE_PATH_STYLE_ENDPOINT=true

# Global overtime multiplier applied to approved overtime hours
# (Sprint 8 decision: env-configurable only, no settings UI).
PAYROLL_OVERTIME_MULTIPLIER=1.25

# Total approved overtime hours per employee per payroll period above
# this value is flagged in the Payroll Exceptions report (Sprint 50).
PAYROLL_OVERTIME_EXCEPTION_THRESHOLD_HOURS=20

# AI provider for AI Insights. Only "stub" (local, deterministic,
# no network calls, no credentials) is implemented; any other value
# throws at boot. Real provider selection is an open decision.
AI_PROVIDER=stub

VITE_APP_NAME="${APP_NAME}"

# Error Monitoring (Sprint 55)
# Gated integration. If left empty, Sentry monitoring remains completely disabled.
# SENTRY_LARAVEL_DSN=https://your-public-key@o0.ingest.sentry.io/your-project-id
# SENTRY_TRACES_SAMPLE_RATE=0.0

